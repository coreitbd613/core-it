// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client"
  output        = "../generated/prisma"
  moduleFormat  = "cjs"
  runtime       = "nodejs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum AuthScope {
  CLIENT
  ADMIN
}

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  password       String?
  name           String?
  googleId       String?        @unique
  avatarUrl      String?
  contactNumber  String?
  whatsappNumber String?
  role           Role           @default(USER)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  refreshTokens  RefreshToken[]
  domainOrders   DomainOrder[]
  hostingOrders  HostingOrder[]
}

model RefreshToken {
  id         String    @id @default(uuid())
  hash       String
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  scope      AuthScope @default(CLIENT)
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  @@index([userId])
}

enum DomainOrderStatus {
  PENDING
  COMPLETED
  REJECTED
}

model DomainOrder {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  domainName String
  tld        String
  years      Int    @default(1)

  priceUsd     Decimal
  priceBdt     Decimal
  exchangeRate Decimal

  status    DomainOrderStatus @default(PENDING)
  adminNote String?

  registrantFirstName    String
  registrantLastName     String
  registrantAddress1     String
  registrantAddress2     String?
  registrantCity         String
  registrantStateProvince String
  registrantPostalCode   String
  registrantCountry      String
  registrantPhone        String
  registrantEmail        String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

enum HostingOrderStatus {
  PENDING
  COMPLETED
  REJECTED
}

model HostingOrder {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Snapshot of the plan at order time, so a later price/spec change never
  // rewrites the terms of a past order.
  planSlug     String
  planName     String
  vcpu         Int
  ramGb        Int
  storageGb    Int
  bandwidthTb  Int
  priceUsd     Decimal
  priceBdt     Decimal

  status    HostingOrderStatus @default(PENDING)
  adminNote String?

  fullName String
  email    String
  phone    String
  company  String?
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}
